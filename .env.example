# Copy this file to .env and fill in your API keys.
# All keys are free with a basic account registration.
# Never commit .env to version control.

# VirusTotal — https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute, 500/day
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# AbuseIPDB — https://www.abuseipdb.com/register
# Free tier: 1,000 requests/day
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# AlienVault OTX — https://otx.alienvault.com/accounts/register
# Free tier: No stated limit
OTX_API_KEY=your-otx-api-key

# NIST NVD — https://nvd.nist.gov/developers/request-an-api-key
# Free tier: 50 requests/30s (5/30s without key — key is optional but recommended)
NVD_API_KEY=your-nvd-api-key

# CISA KEV — no key required, automatically used for CVE lookups

# ── Always-on free sources (no key required) ──────────────────────────────────
# MalwareBazaar — https://bazaar.abuse.ch/api/ — file hash lookups, no key needed
# URLScan.io    — https://urlscan.io/           — URL/domain/IP scan history, no key needed
# WHOIS         — standard protocol             — domain registration info, no key needed

# ── Optional community/paid sources ───────────────────────────────────────────

# GreyNoise — https://viz.greynoise.io/signup
# Free community tier: classify IPs as internet noise vs targeted threats
GREYNOISE_API_KEY=your-greynoise-api-key

# Shodan — https://account.shodan.io/
# Paid plan: open ports, banners, and CVEs on any internet-connected host
SHODAN_API_KEY=your-shodan-api-key
